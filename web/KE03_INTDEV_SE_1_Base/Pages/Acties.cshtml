@page
@* @model ActiesModel *@
@{
    ViewData["Title"] = "Acties";
}

<div class="matrix-page">

    <section class="actions-section">

        <div class="section-header">
            <h3>ACTIES EN AANBIEDINGEN</h3>
        </div>

        <div class="actions-grid">

            <div class="action-card action-folder">
                <div class="action-label">ONZE FOLDER</div>
                <div class="folder-preview">
                    <div class="folder-line"></div>
                    <div class="folder-shape"></div>
                </div>
                <span>BEKIJK</span>
            </div>

            <div class="action-card action-small">
                <h4>30% KORTING</h4>
                <p>OP MATRIX LEKKERNIJEN</p>
            </div>

            <div class="action-card placeholder-card"></div>

            <div class="action-card placeholder-card"></div>

        </div>

        <div class="big-discount-banner">
            <span>75% KORTING!</span>
        </div>

        <div class="bottom-actions-grid">

            <div class="action-card bottom-large">
                <h4>1 + 1</h4>
                <p>GRATIS</p>
            </div>

            <div class="action-card placeholder-card"></div>

            <div class="action-card placeholder-card"></div>

        </div>

    </section>

</div>
@* Aangepast door Tobias *@
             
@page
@model KE03_INTDEV_SE_1_Base.Pages.BestellingenModel

@{
    ViewData["Title"] = "Bestellingen";
}
<link rel="stylesheet" href="~/css/Bestellingen.css" /> 
<div class="bestellingen-page">

    <h3>Mijn Bestellingen</h3>

    @if (Model.Orders == null || !Model.Orders.Any())
    {
        <div class="bestellingen-empty">
            <p>Er zijn geen bestellingen gevonden.</p>
            <p>Klantbestellingen gevonden: @(Model.Orders == null ? 0 : Model.Orders.Count)</p>
            <p>Controleer de databaseverbinding of vul testdata in.</p>
        </div>
    }
    else
    {
        @foreach (var bestelling in Model.Orders)
        {
            <div class="bestellingen-card">

                <div class="bestellingen-header">
                    <h2>@bestelling.OrderDate.ToString("dd-MM-yyyy") - Bestelnummer @bestelling.OrderId</h2>
                    <p>Status: @bestelling.OrderStatus</p>
                </div>

                @if (Model.OrderLines != null && Model.OrderLines.ContainsKey(bestelling.OrderId))
                {
                    @foreach (var product in Model.OrderLines[bestelling.OrderId])
                    {
                        <div class="row">
                            <div class="bestellingen-meta">
                                <div class="bestellingen-product-image">
                                    <img src="https://cataas.com/cat?width=100&height=100&random=@product.ProductEAN" alt="Product foto" />
                                </div>
        
                                @* Deze nieuwe container zorgt ervoor dat de tekst onder elkaar stroomt *@
                                <div class="bestellingen-product-info">
                                    <h3>@product.ProductNaam</h3>
                                    <p class="product-qty">Aantal: @product.Quantity</p>
                                    <p class="product-subprice">Prijs: € @((product.PricePerUnit * product.Quantity).ToString("F2"))</p>
                                </div>
                            </div>
                        </div>
                    }

                    {
                        var productenTotaal = Model.OrderLines[bestelling.OrderId].Sum(p => p.PricePerUnit * p.Quantity);
                        var verzendkosten = 4.99m; 
                        var totaalPrijs = productenTotaal + verzendkosten;
                            
                        <div class="row order-summary-container">
                            <div class="order-summary-line">
                                Subtotaal: € @productenTotaal.ToString("F2")
                            </div>
                            <div class="order-summary-line summary-spacing">
                                Verzendkosten: € @verzendkosten.ToString("F2")
                            </div>
                            <div class="order-summary-total">
                                <span>Totaal te betalen: </span>
                                <span class="total-price-amount">€ @totaalPrijs.ToString("F2")</span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="bestellingen-meta">Geen producten gevonden voor deze bestelling.</div>
                }

            </div>
        }
    }

</div>

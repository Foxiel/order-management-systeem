@page
@model IndexModel
@{
    ViewData["Title"] = "Matrix Inc";
}

<div class="matrix-page">
    <!-- Gemaakt door Jesse -->
    <!-- Aangepast door Tristan. Aanpassing hardcoded producten klanten er uitgehaalt -->
    <section class="hero-section">
        <div class="hero-card">

            <button class="hero-arrow left" id="prevBtn">
                &lt;
            </button>

            <div class="hero-content">
                <div class="hero-overlay">

                    <div class="hero-top">
                        acties
                    </div>

                    <div class="hero-center">
                        <div class="hero-promo-box">
                            <div class="hero-promo-text">
                                <h2 id="heroTitle">
                                    TIJDELIJKE ACTIES
                                </h2>

                                <p id="heroDesc">
                                    Ontdek de beste deals voor jouw onderdelen.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="hero-bottom">
                        <a asp-page="/Acties" class="promo-btn">
                            NU BEKIJKEN
                        </a>
                    </div>

                </div>
            </div>

            <button class="hero-arrow right" id="nextBtn">
                &gt;
            </button>

        </div>
    </section>

    <section class="category-section">

        <div class="category-header">
            <h2>Categorieën</h2>

            <a asp-page="/Categorieën" class="show-all-btn">
                TOON ALLE
            </a>
        </div>

        <div class="category-wrapper">

            <button class="category-side-arrow left-arrow">
                &#10094;
            </button>

            <div class="category-slider">

                <div class="category-grid" id="categoryGrid">

                    <a asp-page="/Categorieën" asp-route-category="licht" class="category-card">
                        <div class="category-image">
                            <img src="https://aleatori.cat/random" alt="Licht">
                        </div>

                        <div class="category-content">
                            <h3>Licht</h3>
                            <p>Moderne lichten.</p>
                        </div>
                    </a>

                    <a asp-page="/Categorieën" asp-route-category="beveiliging" class="category-card">
                        <div class="category-image">
                            <img src="https://aleatori.cat/random" alt="Beveiliging">
                        </div>

                        <div class="category-content">
                            <h3>Beveiliging</h3>
                            <p>Mechanische producten voor bescherming.</p>
                        </div>
                    </a>

                    <a asp-page="/Categorieën" asp-route-category="batterijen" class="category-card">
                        <div class="category-image">
                            <img src="https://aleatori.cat/random" alt="Batterijen">
                        </div>

                        <div class="category-content">
                            <h3>Batterijen</h3>
                            <p>Alle soorten batterijen.</p>
                        </div>
                    </a>

                    <a asp-page="/Categorieën" asp-route-category="auto-onderdelen" class="category-card">
                        <div class="category-image">
                            <img src="https://aleatori.cat/random" alt="Auto onderdelen">
                        </div>

                        <div class="category-content">
                            <h3>Auto onderdelen</h3>
                            <p>Onderdelen voor reparatie.</p>
                        </div>
                    </a>

                </div>

            </div>

            <button class="category-side-arrow right-arrow">
                &#10095;
            </button>

        </div>

    </section>

    <section class="products-section">

        <div class="section-header">
            <h2>VEEL VERKOCHTE PRODUCTEN</h2>
        </div>

        <div class="products-grid">

            @foreach (var product in Model.Products.Take(3))
            {
                var imageUrl = string.IsNullOrWhiteSpace(product.ImageUrl)
                ? "https://aleatori.cat/random"
                : product.ImageUrl;

                <div class="product-card">

                    <div class="product-image">
                        <a asp-page="/Producten" asp-route-id="@product.ProductEAN">
                            <img src="@imageUrl"
                                 alt="@product.ProductName"
                                 class="category-image">
                        </a>
                    </div>

                    <div class="product-content">

                        <h3>@product.ProductName</h3>

                        <p>
                            @product.ProductDescription
                        </p>

                        <div class="product-bottom">

                            <div class="product-price">
                                @product.ProductPrice.ToString("C")
                            </div>

                            <a class="product-btn" asp-page="/Producten" asp-route-id="@product.ProductEAN">
                                BEKIJK
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </section>

</div>

@section Scripts {
    <script src="~/js/Index.js"></script>
}
@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
    <main class="matrix-main">
        <!-- Header Section -->
        <section class="matrix-header">
            <div class="header-box">
                <h1>[ORDER MANAGEMENT SYSTEM]</h1>
                <p class="header-subtitle">Matrix Interface v1.0</p>
            </div>
        </section>

        <!-- Info Box -->
        <section class="matrix-info-box">
            <!-- Acties / Promotions -->
            <div class="promotions">
                <div class="promo-header">ACTIES</div>
                <div class="promo-content">
                    <p>Bekijk onze actuele aanbiedingen en kortingen.</p>
                    <a class="btn btn-primary" asp-page="/Products?category=acties">Bezoek acties</a>
                </div>
            </div>

            <div class="info-header">[SYSTEM INFORMATION]</div>
        </section>

        <!-- Customers Table Section -->
        <section class="matrix-table-section">
            <div class="table-header">[CUSTOMERS DATABASE]</div>
            <table class="matrix-table">
                <thead>
                    <tr>
                        <th>&gt; Klant</th>
                        <th>&gt; Aantal Orders</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Customers)
                    {        
                        <tr>
                            <td>@Html.DisplayName(c.Name)</td>
                            <td>@Html.DisplayName(c.Orders.Count.ToString())</td>           
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </main>

    <!-- Right Sidebar Cards -->
    <aside class="matrix-cards-panel">
        <div class="cards-header">
            <h3>[STATS]</h3>
        </div>
        <div class="card-container">
            <div class="matrix-card">
                <div class="card-title">[TOTAL ORDERS]</div>
                <div class="card-value">@Model.Customers.Sum(c => c.Orders.Count)</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[TOTAL CUSTOMERS]</div>
                <div class="card-value">@Model.Customers.Count</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[SYSTEM STATUS]</div>
                <div class="card-value">ONLINE</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[LAST UPDATE]</div>
                <div class="card-value">@DateTime.Now.ToString("HH:mm:ss")</div>
            </div>
        </div>
        <div class="cards-footer">
            <p>[END TRANSMISSION]</p>
        </div>
    </aside>
</div>

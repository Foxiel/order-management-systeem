@page
@model IndexModel
@{
    ViewData["Title"] = "Matrix Inc";
}

<div class="matrix-page">

    <!-- HERO SECTION -->
    <section class="hero-section">

        <div class="hero-overlay"></div>

        <div class="hero-content">

            <h1>MATRIX INC</h1>

            <p>
                One place for all your mechanical parts.
            </p>

            <a class="hero-btn" asp-page="/Products">
                SHOP NOW
            </a>

        </div>

    </section>

    <!-- CATEGORY SECTION -->
    <section class="category-section">

        <div class="section-header">
            <h2>CATEGORIES</h2>
        </div>

        <div class="category-grid">

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Lighting"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Lighting</h3>
                    <p>Modern smart lighting systems.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Security"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Security</h3>
                    <p>Protect your home with smart systems.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Networking"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Networking</h3>
                    <p>Routers, cables and smart networking.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Tools"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Tools</h3>
                    <p>Professional installation equipment.</p>
                </div>

            </div>

        </div>

    </section>

    <!-- PRODUCTS -->
    <section class="products-section">

        <div class="section-header">
            <h2>FEATURED PRODUCTS</h2>
        </div>

        <div class="products-grid">

            @foreach (var c in Model.Customers)
            {
                <div class="product-card">

                    <div class="product-image">
                        <a href="https://aleatori.cat/random" target="_blank">

                            <img src="https://aleatori.cat/random"
                                 alt="product"
                                 class="category-image">

                        </a>
                    </div>

                    <div class="product-content">

                        <h3>@c.Name</h3>

                        <p>
                            mechanical components
                        </p>

                        <div class="product-bottom">

                            <div class="product-price">
                                @c.Orders.Count Orders
                            </div>

                            <a class="product-btn" href="#">
                                VIEW
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </section>

    <!-- PROMOTION SECTION -->
    <section class="promo-section">

        <div class="promo-box">

            <div class="promo-text">

                <h2>LIMITED OFFERS</h2>

                <p>
                    Discover the newest smart home upgrades
                    and installation equipment.
                </p>

            </div>

            <a class="promo-btn" asp-page="/Products">
                EXPLORE
            </a>

        </div>

    </section>

</div>
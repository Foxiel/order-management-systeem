@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="matrix-container">
    <!-- Left Sidebar Navigation -->
    <aside class="matrix-sidebar">
        <div class="sidebar-header">
            <h3>[MENU]</h3>
        </div>
        <nav class="sidebar-nav">
            <ul>
                <li><a href="#" class="nav-item-active">> Home</a></li>
                <li><a href="#" class="nav-item">> Orders</a></li>
                <li><a href="#" class="nav-item">> Customers</a></li>
                <li><a href="#" class="nav-item">> Products</a></li>
                <li><a href="#" class="nav-item">> Reports</a></li>
                <li><a href="#" class="nav-item">> Settings</a></li>
            </ul>
        </nav>
        <div class="sidebar-footer">
            <p>[SYSTEM ONLINE]</p>
            <p class="system-status">STATUS: ACTIVE</p>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="matrix-main">
        <!-- Header Section -->
        <section class="matrix-header">
            <div class="header-box">
                <h1>[ORDER MANAGEMENT SYSTEM]</h1>
                <p class="header-subtitle">Matrix Interface v1.0</p>
            </div>
        </section>

        <!-- Info Box -->
        <section class="matrix-info-box">
            <div class="info-header">[SYSTEM INFORMATION]</div>
            <div class="info-content">
                <p>
                    Dit project kun je gebruiken als startpunt voor de individuele inleveropdracht: 
                    <a href="https://moodle.zuyd.nl/mod/resource/view.php?id=1262065">KE03_INTDEV_SE_1</a>
                </p>
                <ul>
                    <li><strong>> Wat ga je maken:</strong> Een gebruiksvriendelijk online bestelsysteem voor een klant om producten te bestellen.</li>
                    <li>
                        <strong>> Hoe ga je dit maken:</strong>
                        <ul class="nested-list">
                            <li>- Individuele inleveropdracht</li>
                            <li>- Pas de principes van HCI toe</li>
                            <li>- Maak gebruik van: .NET core razor pages</li>
                            <li>- Maak gebruik van git en github</li>
                        </ul>
                    </li>
                    <li><strong>> Data Access Layer:</strong> Je krijgt een DAL meegeleverd. Ben creatief!</li>
                </ul>
            </div>
        </section>

        <!-- Customers Table Section -->
        <section class="matrix-table-section">
            <div class="table-header">[CUSTOMERS DATABASE]</div>
            <table class="matrix-table">
                <thead>
                    <tr>
                        <th>&gt; Klant</th>
                        <th>&gt; Aantal Orders</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Customers)
                    {        
                        <tr>
                            <td>@Html.DisplayName(c.Name)</td>
                            <td>@Html.DisplayName(c.Orders.Count.ToString())</td>           
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </main>

    <!-- Right Sidebar Cards -->
    <aside class="matrix-cards-panel">
        <div class="cards-header">
            <h3>[STATS]</h3>
        </div>
        <div class="card-container">
            <div class="matrix-card">
                <div class="card-title">[TOTAL ORDERS]</div>
                <div class="card-value">@Model.Customers.Sum(c => c.Orders.Count)</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[TOTAL CUSTOMERS]</div>
                <div class="card-value">@Model.Customers.Count</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[SYSTEM STATUS]</div>
                <div class="card-value">ONLINE</div>
            </div>
            <div class="matrix-card">
                <div class="card-title">[LAST UPDATE]</div>
                <div class="card-value">@DateTime.Now.ToString("HH:mm:ss")</div>
            </div>
        </div>
        <div class="cards-footer">
            <p>[END TRANSMISSION]</p>
        </div>
    </aside>
</div>

@page
@model IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Matrix Inc";
}

<div class="matrix-page">

    <!-- HERO / PROMO CAROUSEL -->
    <section class="hero-section">

        <div class="hero-card">

            <button class="hero-arrow left" id="prevBtn">
                &lt;
            </button>

            <div class="hero-content">

                <div class="hero-overlay">

                    <div class="hero-top">
                        acties
                    </div>

                    <div class="hero-center">

                        <div class="hero-promo-box">

                            <div class="hero-promo-text">
                                <h2 id="heroTitle">
                                    TIJDELIJKE DEALS
                                </h2>

                                <p id="heroDesc">
                                    Ontdek de beste deals voor jouw onderdelen.
                                </p>
                            </div>

                        </div>

                    </div>

                    <div class="hero-bottom">
                        <a href="#" class="promo-btn">
                            NU BEKIJKEN
                        </a>
                    </div>

                </div>

            </div>

            <button class="hero-arrow right" id="nextBtn">
                &gt;
            </button>

        </div>

    </section>

    <!-- CATEGORY SECTION -->
    <section class="category-section">

        <div class="section-header">
            <h2>CATEGORIEËn</h2>
        </div>

        <div class="category-grid">

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Licht"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>licht</h3>
                    <p>Moderne lichten.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Beveiliging"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Beveiliging</h3>
                    <p>Pmechaniche producten voor jouw bescherming.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Batterijen"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Batterijen</h3>
                    <p>Alle soorten batterijen die je nodig kan hebben.</p>
                </div>

            </div>

            <div class="category-card">

                <div class="category-image">
                    <a href="https://aleatori.cat/random" target="_blank">

                        <img src="https://aleatori.cat/random"
                             alt="Auto onderdelen"
                             class="category-image">

                    </a>
                </div>

                <div class="category-content">
                    <h3>Auto onderdelen</h3>
                    <p>Auto onderdelen voor reparatie.</p>
                </div>

            </div>

        </div>

    </section>

	<!-- PRODUCTS -->
	<section class="products-section">

		<div class="section-header">
			<h2>VEEL VERKOCHTEN PRODUCTEN</h2>
		</div>

		<div class="products-grid">

			@foreach (var p in Model.Products)
			{
				<div class="product-card">

					<div class="product-image">
						<a href="#">
							<img src="https://aleatori.cat/random"
								 alt="@p.Name"
								 class="category-image">
						</a>
					</div>

					<div class="product-content">

						<h3>@p.Name</h3>

						<p>
							@p.Description
						</p>

						<div class="product-bottom">

							<div class="product-price">
								@p.Price.ToString("C")
							</div>

							<a class="product-btn" asp-page="/Producten" asp-route-id="@p.Id">
								BEKIJK
							</a>

						</div>

					</div>

				</div>
			}

		</div>

	</section>

    <!-- CUSTOMERS -->
    <section class="customers-section">

        <div class="section-header">
            <h2>KLIËNTEN</h2>
        </div>

        <div class="products-grid">

            @foreach (var c in Model.Customers)
            {
                <div class="product-card">

                    <div class="product-image">
                        <a href="#">

                            <img src="https://aleatori.cat/random"
                                 alt="customer"
                                 class="category-image">

                        </a>
                    </div>

                    <div class="product-content">

                        <h3>@c.Name</h3>

                        <p>
                            @c.Address
                        </p>

                        <div class="product-bottom">

                            <div class="product-price">
                                @c.Orders.Count orders
                            </div>

                            <a class="product-btn" href="#">
                                BEKIJK
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>

    </section>

</div>
@section Scripts {
    <script src="~/js/promo.js"></script>
}
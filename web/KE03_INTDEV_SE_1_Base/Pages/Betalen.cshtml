@page
@model BetalenModel
@{
    ViewData["Title"] = "Betalen";
}

<div class="matrix-page">

    <section class="checkout-section">

        <div class="section-header">
            <h2>BETALEN</h2>
        </div>

        <div class="checkout-container">

            <!-- LINKS: BETAALFORMULIER -->
            <form method="post"
                  class="payment-form"
                  id="paymentForm">

                <h3>Gegevens</h3>

                <label>Naam</label>
                <input name="Naam"
                       type="text"
                       placeholder="Uw naam"
					   required
                       asp-for="Naam" />

                <label>Telefoonnummer</label>
                <input name="Telefoon"
                       type="text"
                       placeholder="06 12345678"
                       required 
                       asp-for="Telefoon" />

                <label>E-mailadres</label>
                <input name="Email"
                       type="email"
                       placeholder="naam@email.nl"
                       required 
                       asp-for="Email" />

                <h3>Adres</h3>

                <label>Straat en huisnummer</label>
                <input type="text"
                       placeholder="Hoofdstraat 1"
                       required />

                <div class="payment-row">

                    <div>
                        <label>Postcode</label>
                        <input type="text"
                               placeholder="1234 AB"
                               required />
                    </div>

                    <div>
                        <label>Plaats</label>
                        <input type="text"
                               placeholder="Maastricht"
                               required />
                    </div>

                </div>

                <h3>Betaalmethode</h3>

                <div class="payment-methods">

                    <label class="payment-option">
                        <input type="radio"
                               name="paymentMethod"
                               checked />
                        <span>iDEAL</span>
                    </label>

                    <label class="payment-option">
                        <input type="radio"
                               name="paymentMethod" />
                        <span>Creditcard</span>
                    </label>

                    <label class="payment-option">
                        <input type="radio"
                               name="paymentMethod" />
                        <span>PayPal</span>
                    </label>

                </div>

                <!-- Hier komt de winkelwagen uit localStorage -->
                <input type="hidden"
                       name="CartJson"
                       id="cartJsonInput" />

                <button type="submit"
                        class="pay-btn">
                    BESTELLING PLAATSEN
                </button>

            </form>

            <!-- RECHTS: KOSTEN -->
            <aside class="checkout-summary">

                <h3>Kosten</h3>

                <div id="paymentProducts">
                    <!-- Producten worden door betalen.js gevuld -->
                </div>

                <div class="summary-divider"></div>

                <div class="summary-line">
                    <span>Totaal artikelen:</span>
                    <span id="paymentItemCount">0</span>
                </div>

                <div class="summary-line">
                    <span>Subtotaal:</span>
                    <span id="paymentSubtotal">€0.00</span>
                </div>

                <div class="summary-line">
                    <span>Verzendkosten:</span>
                    <span id="paymentShipping">€0.00</span>
                </div>

                <div class="summary-divider"></div>

                <div class="summary-line total">
                    <span>Totaal:</span>
                    <span id="paymentTotal">€0.00</span>
                </div>

            </aside>

        </div>

    </section>

</div>

@section Scripts
{
    <script src="~/js/betalen.js"></script>
}
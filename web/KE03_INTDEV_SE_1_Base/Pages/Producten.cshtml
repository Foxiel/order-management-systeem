@page
@model KE03_INTDEV_SE_1_Base.Pages.ProductenModel
@{
    ViewData["Title"] = "Producten";
}

<div class="matrix-page">
    <!-- Gemaakt door  -->
    <!-- Aangepast door Tristan. Aanpassing Hardcoded producten er uitgehaalt -->
    <section class="products-section">

        <div class="section-header">
            <h2>PRODUCTEN</h2>
        </div>

        <div class="products-grid">

            @if (Model.Products.Any())
            {
                foreach (var product in Model.Products)
                {
                    var imageUrl = !string.IsNullOrWhiteSpace(product.ImageUrl)
                    ? product.ImageUrl
                    : $"https://cataas.com/cat?width=400&height=300&random={product.ProductEAN}";

                    <div class="product-card">

                        <div class="product-image">
                            <img src="@imageUrl"
                                 alt="@product.ProductName" />
                        </div>

                        <div class="product-content">

                            <h3>@product.ProductName</h3>

                            <p>
                                @product.ProductDescription
                            </p>

                            <div class="product-bottom">

                                <div class="product-price">
                                    € @product.ProductPrice.ToString("F2")
                                </div>
                                <button type="button"
                                        class="product-btn add-to-cart-btn"
                                        data-product-id="@product.ProductEAN"
                                        data-product-name="@product.ProductName"
                                        data-product-price="@product.ProductPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                        data-product-image="@imageUrl">
                                    Aan wagen toevoegen
                                </button>

                            </div>

                        </div>

                    </div>
                }
            }
            else
            {
                <p>Er zijn geen producten gevonden.</p>
            }

        </div>

    </section>

</div>

@section Scripts {
    <script src="~/js/producten.js"></script>
}